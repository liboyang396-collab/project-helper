APP_NAME=Project Helper
DATABASE_URL=sqlite:///./storage/project_helper.db
REPO_STORAGE_DIR=./storage/repos
GIT_CLONE_TIMEOUT_SECONDS=120
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Model provider: deepseek or ark
MODEL_PROVIDER=ark

# DeepSeek uses an OpenAI-compatible API. Change the model if your account exposes a newer DeepSeek V4 alias.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.2

# Volcengine Ark Responses API. Never commit real keys.
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/responses
ARK_MODEL=doubao-seed-2-0-mini-260215
ARK_TEMPERATURE=0.2
ARK_ENABLE_WEB_SEARCH=true
ARK_WEB_SEARCH_MAX_KEYWORD=3
ARK_TIMEOUT_SECONDS=120
